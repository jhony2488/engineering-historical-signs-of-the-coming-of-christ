# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Spline 3D (opcional) — Export → Code → React no editor; NÃO use .spline do editor
# URL prod.spline.design/.../scene.splinecode OU arquivo .splinecode em public/
# NEXT_PUBLIC_SPLINE_SCENE_URL=https://prod.spline.design/SEU_ID/scene.splinecode

# Fonte de dados: db (Prisma/Supabase) ou fastapi (motor Python)
NEXT_PUBLIC_DATA_SOURCE=db

# API FastAPI (quando DATA_SOURCE=fastapi)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Prisma — connection string Supabase PostgreSQL
# Pooler (app): port 6543 + ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct (migrations): port 5432
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Usar dados de demonstração quando API/DB indisponível
NEXT_PUBLIC_USE_MOCK=false

# Autenticação área admin (histórico, simulador, grafo)
# Gere AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=change-me-use-openssl-rand-base64-32-chars-min
ADMIN_USERNAME=admin
# Gere com: npm run auth:hash-password -- sua-senha-segura
ADMIN_PASSWORD_HASH=

# Google Analytics 4 (gratuito) — rastreia apenas / e /rankings
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Data API (opcional) — métricas na página /insights
# Service account com papel Leitor na propriedade GA4
GA_PROPERTY_ID=123456789
GA_CLIENT_EMAIL=analytics@seu-projeto.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IndexNow / Google Indexing (SEO)
INDEXNOW_KEY=
INDEXNOW_HOST=
SITEMAP_URL=
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
GOOGLE_INDEXING_KEY_FILE=

INDEXNOW_KEY="your-indexnow-key-for-search-engine-submission"
INDEXNOW_HOST="https://your-domain.com"
# =============================================================================
# Segurança da cadeia de suprimentos (supply chain) — npm
# =============================================================================
#
# Ataques comuns em pacotes npm:
#   - Conta de mantenedor comprometida (versão maliciosa publicada em horas)
#   - Typosquatting (nome parecido com pacote legítimo)
#   - Scripts de install/postinstall que exfiltram env, credenciais ou rodam código
#   - Dependências instaladas direto de repositório Git (tag/commit alterável)
#
# As opções abaixo reduzem a superfície de ataque. Não substituem revisão de
# dependências, `npm audit` e lockfile versionado em CI.
#
# Referências:
#   https://docs.npmjs.com/cli/v10/using-npm/config#ignore-scripts
#   https://docs.npmjs.com/cli/v10/using-npm/config#min-release-age
#   https://docs.npmjs.com/cli/v11/using-npm/config#allow-git
#
# =============================================================================

# Aguarda N dias antes de aceitar versões recém-publicadas no registry.
# Mitiga janela em que uma versão comprometida ainda não foi detectada/removida.
# Trade-off: patches de segurança legítimos também ficam bloqueados por esse período.
min-release-age=7

# Não executa scripts de lifecycle (preinstall, install, postinstall, prepare…)
# de dependências transitivas durante `npm install`.
# Mitiga o vetor mais usado em ataques: código arbitrário na instalação.
#
# IMPACTO NESTE PROJETO:
#   - O postinstall do Prisma (download do query engine) NÃO roda automaticamente.
#   - Após `npm install` ou `npm ci`, execute sempre:
#       npm run db:generate
#     (ou `npx prisma generate` antes de `npm run build` / `npm run dev`).
ignore-scripts=true

# Impede instalação de pacotes via URL git (github:, git+ssh:, etc.).
# Mitiga dependências não imutáveis e fora do controle do registry npm.
allow-git=none

# =============================================================================
# Boas práticas complementares (fora deste arquivo)
# =============================================================================
#
#   1. Preferir `npm ci` em CI/CD (instala exatamente o lockfile).
#   2. Rodar `npm audit` periodicamente; corrigir high/critical com critério.
#   3. Evitar `npm install <pacote>` sem revisar o repositório e o mantenedor.
#   4. Não commitar `.env` / tokens; scripts maliciosos costumam ler process.env.
#   5. Revisar `overrides` em package.json — fixam versões e bloqueiam transitivas.
#   6. Em atualizações grandes, testar localmente antes de merge (build + test).
#
# =============================================================================

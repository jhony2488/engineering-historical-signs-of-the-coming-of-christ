// Prisma schema — leitura do Supabase PostgreSQL (mesmo banco do backend)
// DDL principal: backend/supabase/migrations/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ResultadoEscatologico {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dataReferencia     DateTime @map("data_referencia") @db.Date
  faseAtual          String   @map("fase_atual")
  probabilidadeFase  Float    @map("probabilidade_fase")
  indiceGlobal       Float    @map("indice_global")
  confianca          Float
  jsonAnaliseIa      Json     @map("json_analise_ia")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([dataReferencia])
  @@map("resultados_escatologicos")
}

model RankingProbabilistico {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dataReferencia     DateTime @map("data_referencia") @db.Date
  posicao            Int
  candidatoId        String   @map("candidato_id")
  nome               String
  personagem         String
  probabilidadeAtual Float    @map("probabilidade_atual")
  tendencia24h       Float    @default(0) @map("tendencia_24h")
  fatorPrincipal     String?  @map("fator_principal")
  scoresCriterio     Json?    @default("{}") @map("scores_criterio")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([dataReferencia, personagem])
  @@map("ranking_probabilistico")
}

model CandidatoPerfil {
  id             String   @id
  nome           String
  personagem     String
  scoresCriterio Json     @default("{}") @map("scores_criterio")
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("candidatos_perfil")
}

model SnapshotPeriodo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  janela         String
  dataReferencia DateTime @map("data_referencia") @db.Date
  dados          Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([janela, dataReferencia])
  @@map("snapshots_periodo")
}

model ParametroFase {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  versao     Int
  ativo      Boolean  @default(false)
  emissoes   Json
  transicoes Json
  aprovado   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("parametros_fase")
}

model GrafoNo {
  nodeId    String   @id @map("node_id")
  tipo      String
  attrs     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("grafo_nos")
}

model GrafoAresta {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId  String   @map("source_id")
  targetId  String   @map("target_id")
  relacao   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("grafo_arestas")
}

model BaselineEscatologico {
  id                 String   @id @default("global")
  versao             String
  estatisticas       Json
  overview           Json
  categorias         Json     @default("[]")
  profeciasPendentes Json     @default("[]") @map("profecias_pendentes")
  sinaisGerais       Json     @default("[]") @map("sinais_gerais")
  atualizacoes       Json     @default("[]")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("baseline_escatologico")
}

model ArquivoProfetico {
  id                  String    @id
  titulo              String
  status              String
  categoria           String
  referencias         Json      @default("[]")
  periodoCumprimento  String?   @map("periodo_cumprimento")
  faseEscatologica    String?   @map("fase_escatologica")
  energia             String?
  dimensao            String?
  descricao           String?
  dados               Json      @default("{}")
  cumpridaEm          DateTime? @map("cumprida_em") @db.Date
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime? @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("arquivo_profetico")
}

model NewsletterSubscriber {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String    @unique
  status           String    @default("active")
  unsubscribeToken String    @unique @map("unsubscribe_token")
  source           String?   @default("web")
  subscribedAt     DateTime  @default(now()) @map("subscribed_at") @db.Timestamptz(6)
  unsubscribedAt   DateTime? @map("unsubscribed_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@map("newsletter_subscribers")
}

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# LLM (Groq primary, OpenRouter fallback)
GROQ_API_KEY=
OPENROUTER_API_KEY=
LLM_DRY_RUN=false

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# API
ADMIN_API_KEY=change-me-in-production
API_RATE_LIMIT=30/minute

# Batch
BATCH_CRON_TZ=America/Sao_Paulo
BATCH_HOUR=4
MAX_DOCUMENTS_PER_DAY=50
EMBEDDING_BATCH_SIZE=8
BGE_MODEL_NAME=BAAI/bge-m3

# Thresholds
FALSE_LEADER_INCONGRUENCE_THRESHOLD=0.7
PHASE_CONFIDENCE_MIN=0.55
PHASE_TRANSITION_MARGIN_MAX=0.15
AUTO_APPROVE_CRITERIA=false

# Weights (correlation layer)
WEIGHT_BAYES=0.35
WEIGHT_HMM=0.35
WEIGHT_LLM=0.30

# ACLED (optional — requer key + email registrados em acleddata.com)
ACLED_API_KEY=
ACLED_EMAIL=

# API.Bible (opcional — corpus teológico expandido)
API_BIBLE_KEY=
API_BIBLE_ID=de4e12af7f28f599-02

# Dados micro (opcional)
REDDIT_ENABLED=false
REDDIT_USER_AGENT=SinaisHistoricosBot/1.0
GOOGLE_TRENDS_ENABLED=false

# Cold storage local
ARCHIVE_DIR=./archive
COLD_STORAGE_YEARS=2
